# ===========================================
# TrackMyCalendar Configuration
# Copy this file to .env and fill in your values
# ===========================================

# ---- Google Calendar ----
# Download credentials.json from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# ---- Microsoft Outlook ----
# Register an app at https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
OUTLOOK_CLIENT_ID=your_client_id_here
OUTLOOK_CLIENT_SECRET=your_client_secret_here
OUTLOOK_TENANT_ID=common

# ---- iCalendar ----
# Path to local .ics file or URL to remote calendar
ICALENDAR_SOURCES=https://calendar.example.com/feed.ics,/path/to/local/calendar.ics

# ---- Notification Settings ----
# Enable/disable notification methods (true/false)
ENABLE_DESKTOP_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSHBULLET_NOTIFICATIONS=false
ENABLE_SOUND_ALERTS=true

# ---- Twilio SMS (optional) ----
# Get credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# ---- Pushbullet (optional) ----
# Get API key from https://www.pushbullet.com/#settings
PUSHBULLET_API_KEY=your_api_key_here

# ---- Reminder Settings ----
# Reminder times in minutes before meeting
REMINDER_TIMES=10,5,0

# How often to check for upcoming meetings (in seconds)
CHECK_INTERVAL=30

# Timezone (e.g., America/New_York, Europe/London, Asia/Kolkata)
TIMEZONE=UTC
