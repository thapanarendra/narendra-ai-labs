# Environment variables for Always-On Meeting Intelligence Agent

# OpenAI API key for transcription and AI features
OPENAI_API_KEY=sk-your-openai-api-key-here

# Hugging Face token for speaker diarization (pyannote)
HF_TOKEN=hf_your-huggingface-token-here

# Jira Integration
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Asana Integration
ASANA_API_TOKEN=your-asana-personal-access-token
ASANA_WORKSPACE_GID=your-workspace-gid
ASANA_PROJECT_GID=your-project-gid
